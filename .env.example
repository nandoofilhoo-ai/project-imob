# Database Configuration
# In docker-compose, use postgresql://postgres:postgres@db:5432/imobi_sdr
# Local local environment, use postgresql://postgres:postgres@localhost:5432/imobi_sdr (or SQLite for light testing: sqlite:///./imobi_sdr.db)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/imobi_sdr

# OpenAI API (For live qualification. Leave empty or dummy to use mock LLM)
OPENAI_API_KEY=sua-openai-key
LLM_MODEL=gpt-4o-mini

# Chatwoot Configuration
CHATWOOT_URL=https://seu-chatwoot.com
CHATWOOT_ACCESS_TOKEN=seu-token
CHATWOOT_ACCOUNT_ID=1

# Evolution API Configuration
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-evolution-key
EVOLUTION_WEBHOOK_URL=http://localhost:8000/webhook/evolution
EVOLUTION_INSTANCE=ImobiliariaAlfa


# General Application Configurations
APP_NAME="Imobi SDR Backend"
APP_ENV=development
