# Database Configuration
# In docker-compose / VPS, use the internal Postgres service name as host.
DATABASE_URL=postgresql://postgres:postgres@db:5432/imobi_sdr

# OpenAI API (leave empty to run in mock mode)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Gemini API (optional; current code still uses OpenAI or mock unless a Gemini provider is implemented)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Chatwoot Configuration
CHATWOOT_URL=https://seu-chatwoot.com
CHATWOOT_ACCESS_TOKEN=seu-token
CHATWOOT_ACCOUNT_ID=1

# Evolution API Configuration
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=sua-evolution-key
EVOLUTION_INSTANCE_TOKEN=sua-instance-token
EVOLUTION_INSTANCE_NAME=Suporte
EVOLUTION_CHANNEL_NAME=WhatsApp Principal Evolution
EVOLUTION_WEBHOOK_URL=https://api.seudominio.com/webhook/evolution
AUTO_SYNC_EVOLUTION_CHANNEL=true
EVOLUTION_INSTANCE=ImobiliariaAlfa

# General Application Configurations
APP_NAME="Imobi SDR Backend"
APP_ENV=production
